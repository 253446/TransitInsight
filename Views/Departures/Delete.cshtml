@model TransitInsight.Models.Departure

@{
    ViewData["Title"] = "Delete Departure";
}

<h1>Delete Departure</h1>

<p>Are you sure you want to delete this departure?</p>

<div class="card p-3">
    <p><strong>Stop Place:</strong> @Model.StopPlace?.Name</p>
    <p><strong>Line:</strong> @Model.LineName</p>
    <p><strong>Destination:</strong> @Model.Destination</p>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>