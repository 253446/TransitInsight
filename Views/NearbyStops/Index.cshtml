@model List<TransitInsight.Models.EnturStopSearchResult>

@{
    ViewData["Title"] = "Nearby Stops";
}

<h1>Nearby Stops</h1>

<p class="text-muted">
    Find stops near your current location or by typing a place.
</p>

<form id="locationForm" asp-action="Search" method="post" class="mb-4">
    @Html.AntiForgeryToken()

    <div class="input-group">
        <input name="selectedPlace"
               id="selectedPlaceInput"
               class="form-control"
               placeholder="Type place, e.g. Horten, Borre, Oslo S" />

        <button id="findNearbyButton" class="btn btn-primary" type="button">
            📍 Find stops near me
        </button>
    </div>

    <input type="hidden" id="latitudeInput" name="latitude" />
    <input type="hidden" id="longitudeInput" name="longitude" />
</form>

<p id="locationStatus" class="text-muted"></p>

@if (ViewBag.SearchInfo != null)
{
    <div class="alert alert-info">
        @ViewBag.SearchInfo
    </div>
}

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Locality</th>
                <th>EnturId</th>
                <th>Departures</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var stop in Model)
        {
            <tr>
                <td>@stop.Name</td>
                <td>@stop.Locality</td>
                <td><code>@stop.EnturId</code></td>
                <td>
                    @if (stop.Departures.Any())
                    {
                        <ul>
                            @foreach (var dep in stop.Departures)
                            {
                                <li>
                                    <strong>@dep.LineName</strong> →
                                    @dep.Destination
                                    (@dep.ExpectedDepartureTime.ToString("HH:mm"))
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">No live departures found</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-secondary">
        No stops found yet.
    </div>
}

@section Scripts {
    <script>
        const button = document.getElementById("findNearbyButton");
        const selectedPlaceInput = document.getElementById("selectedPlaceInput");
        const statusText = document.getElementById("locationStatus");
        const latitudeInput = document.getElementById("latitudeInput");
        const longitudeInput = document.getElementById("longitudeInput");
        const form = document.getElementById("locationForm");

        button.addEventListener("click", () => {
            const selectedPlace = selectedPlaceInput.value.trim();

            if (selectedPlace.length > 0) {
                form.submit();
                return;
            }

            if (!navigator.geolocation) {
                statusText.textContent = "Geolocation is not supported.";
                return;
            }

            statusText.textContent = "Requesting location...";

            navigator.geolocation.getCurrentPosition(
                (position) => {
                    latitudeInput.value = position.coords.latitude;
                    longitudeInput.value = position.coords.longitude;
                    form.submit();
                },
                () => {
                    statusText.textContent = "Location failed. Type a place instead.";
                }
            );
        });
    </script>
}