@model TransitInsight.Models.StopPlace

@{
    ViewData["Title"] = "Create Stop Place";
}

<h1>Create Stop Place</h1>

<form asp-action="Create">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EnturId" class="form-label"></label>
        <input asp-for="EnturId" class="form-control" />
        <span asp-validation-for="EnturId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Locality" class="form-label"></label>
        <input asp-for="Locality" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Latitude" class="form-label"></label>
        <input asp-for="Latitude" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Longitude" class="form-label"></label>
        <input asp-for="Longitude" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>