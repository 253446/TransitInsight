@model TransitInsight.Models.StopPlace

@{
    ViewData["Title"] = "Delete Stop Place";
}

<h1>Delete Stop Place</h1>

<p>Are you sure you want to delete this stop place?</p>

<h3>@Model.Name</h3>
<p>@Model.EnturId</p>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
