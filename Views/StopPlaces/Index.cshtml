@model IEnumerable<TransitInsight.Models.StopPlace>

@{
    ViewData["Title"] = "Stop Places";
}

<h1>Stop Places</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Entur Id</th>
            <th>Locality</th>
            <th>Departures</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td>@item.EnturId</td>
            <td>@item.Locality</td>
            <td>@item.Departures.Count</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>